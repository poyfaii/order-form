function KpiCard({ label, value, icon, accent, sub, delay }) {
return (
<div className=“card-anim” style={{ background:”#15172A”, border:`1px solid ${accent}28`, borderRadius:14, padding:“20px 22px”, position:“relative”, overflow:“hidden”, animationDelay:delay }}>
<div style={{ position:“absolute”, right:18, top:18, fontSize:30, opacity:0.12 }}>{icon}</div>
<div style={{ fontSize:11, color:”#4A5068”, marginBottom:8, textTransform:“uppercase”, letterSpacing:0.6 }}>{label}</div>
<div style={{ fontSize:24, fontWeight:700, color:”#F1F5F9”, fontFamily:”‘IBM Plex Mono’, monospace”, marginBottom:5, letterSpacing:-0.5 }}>{value}</div>
<div style={{ fontSize:12, color:accent, fontWeight:500 }}>{sub}</div>
<div style={{ position:“absolute”, bottom:0, left:0, right:0, height:3, background:`linear-gradient(90deg,${accent}88,transparent)` }} />
</div>
);
}