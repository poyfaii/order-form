export default function App() {
const [expenses, setExpenses] = useState(SEED);
const [nextId, setNextId] = useState(SEED.length + 1);
const [form, setForm] = useState({ date: today(), type: “รายจ่าย”, category: “อาหาร”, amount: “”, description: “” });
const [selectedMonth, setSelectedMonth] = useState(“2025-04”);
const [sidebarOpen, setSidebarOpen] = useState(false);
const [flash, setFlash] = useState(false);

const months = useMemo(() => {
const s = new Set(expenses.map((e) => toMonth(e.date)));
return […s].sort().reverse();
}, [expenses]);

const monthly = useMemo(() => expenses.filter((e) => toMonth(e.date) === selectedMonth), [expenses, selectedMonth]);

const income  = monthly.filter(e => e.type === “รายรับ”).reduce((s, e) => s + e.amount, 0);
const expense = monthly.filter(e => e.type === “รายจ่าย”).reduce((s, e) => s + e.amount, 0);
const balance = income - expense;

const pieData = useMemo(() => {
const map = {};
monthly.filter(e => e.type === “รายจ่าย”).forEach(e => { map[e.category] = (map[e.category]||0) + e.amount; });
return Object.entries(map).map(([name, value]) => ({ name, value, color: CAT_COLORS[name] || “#aaa” }));
}, [monthly]);

const barData = useMemo(() => {
const map = {};
monthly.forEach(e => {
if (!map[e.category]) map[e.category] = { cat: e.category, รายรับ: 0, รายจ่าย: 0 };
map[e.category][e.type] = (map[e.category][e.type]||0) + e.amount;
});
return Object.values(map);
}, [monthly]);

const handleAdd = () => {
if (!form.amount || Number(form.amount) <= 0) return;
const item = { …form, amount: Number(form.amount), id: nextId };
setExpenses(p => [item, …p]);
setNextId(n => n+1);
if (!months.includes(toMonth(form.date))) setSelectedMonth(toMonth(form.date));
setForm({ date: today(), type: “รายจ่าย”, category: “อาหาร”, amount: “”, description: “” });
setFlash(true); setTimeout(() => setFlash(false), 2000);
setSidebarOpen(false);
};

const handleDelete = (id) => setExpenses(p => p.filter(e => e.id !== id));

const inputSt = {
width:“100%”, background:”#1C1F2E”, border:“1px solid #2E3350”,
