{ id:5, date:“2025-04-15”, type:“รายจ่าย”, category:“อาหาร”,    amount:560,   description:“ร้านอาหารญี่ปุ่น” },
{ id:6, date:“2025-04-18”, type:“รายรับ”,  category:“ลงทุน”,    amount:2800,  description:“ปันผลกองทุน” },
{ id:7, date:“2025-04-20”, type:“รายจ่าย”, category:“อื่นๆ”,    amount:800,   description:“ค่าไฟ” },
