const TYPES = [“รายจ่าย”, “รายรับ”];

const CAT_COLORS = {
“อาหาร”:    “#FF6B6B”,
“เงินเดือน”:”#4ECDC4”,
“เดินทาง”:  “#45B7D1”,
“ช้อปปิ้ง”: “#FFA07A”,
“ลงทุน”:    “#98D8C8”,
“อื่นๆ”:    “#C3B1E1”,
